# ── PulseCheck Docker Environment ─────────────────────────────────
# Copy this to backend/.env before running docker-compose up

PORT=4000
MONGODB_URI=mongodb://mongo:27017/pulsecheck
JWT_SECRET=change-me-in-production

# SMTP settings for alert emails (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@pulsecheck.local
